	measure 'YTD Total Deaths' =
			
			IF (
			    [_ShowValueForDates],
			    CALCULATE (
			        [Total Deaths],
			        DATESYTD ( 'Date'[Date] )
			    )
			)
		formatString: 0
		displayFolder: Time intelligence\To-date total\Total Deaths
		lineageTag: 855bcac7-43bb-4e49-8130-c0452b2c70f0

		annotation SQLBI_Template = TimeIntelligence

