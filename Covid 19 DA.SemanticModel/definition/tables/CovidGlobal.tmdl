	measure 'PY Total Deaths' =
			
			IF (
			    [_ShowValueForDates],
			    CALCULATE (
			        [Total Deaths],
			        CALCULATETABLE (
			            DATEADD ( 'Date'[Date], -1, YEAR ),
			            'Date'[DateWithTransactions] = TRUE
			        )
			    )
			)
		formatString: 0
		displayFolder: Time intelligence\Growth\Total Deaths
		lineageTag: 72400632-07d5-4adf-8793-df74a1566452

		annotation SQLBI_Template = TimeIntelligence

		annotation SQLBI_TimeIntelligence = Standard

		annotation SQLBI_CalendarType = Calendar

	measure 'YOY Total Deaths' =
			
			VAR __ValueCurrentPeriod = [Total Deaths]
			VAR __ValuePreviousPeriod = [PY Total Deaths]
			VAR __Result =
			    IF (
			        NOT ISBLANK ( __ValueCurrentPeriod ) && NOT ISBLANK ( __ValuePreviousPeriod ),
			        __ValueCurrentPeriod - __ValuePreviousPeriod
			    )
			RETURN
			    __Result
		formatString: 0
		displayFolder: Time intelligence\Growth\Total Deaths
		lineageTag: 5dd127a4-0183-4ac8-87c3-52e7fb8e1686

		annotation SQLBI_Template = TimeIntelligence

		annotation SQLBI_TimeIntelligence = Standard

		annotation SQLBI_CalendarType = Calendar

	measure 'YOY % Total Deaths' = ```
			
